# Forget-me-not configuration. Copy to vault.toml and edit.
# Anything omitted falls back to the built-in defaults.

[identity]
# Who is in this relationship. Used in analyzer prompts and edge filtering.
human = "Mal"
companion = "Q"

[paths]
# The vault (a folder of markdown files — this IS your memory, own it, back it up).
vault_root = "C:/Users/User/Documents/Obsidian Vault"
# The companion's system-prompt file that boot recall injects into.
system_prompt = "C:/Users/User/.hermes.md"

[models]
# Any OpenAI-compatible endpoint (default: OpenRouter). Set OPENROUTER_API_KEY.
chunker   = "meta-llama/llama-3.3-70b-instruct"   # phase 1: boundary finding
summarizer = "google/gemini-2.5-flash"            # phase 2: cell writing (needs EQ)
ruminator = "google/gemini-2.5-flash"             # contradiction judge (conservative)
# The pilot model (the companion itself) should NOT write its own summaries
# if it over-connects — pick a disciplined summarizer instead.

[recall]
# Boot note budget. Small and warm: most memory stays gray, reachable on demand.
max_cells = 15

[cadence]
# Reflection consolidation triggers (hours / count).
reflect_min_worthy = 3
reflect_min_hours  = 36
